<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>3D Rig & Paint Studio</title>
    <script type="importmap">
        {
            "imports": {
                "three": "https://unpkg.com/three@0.160.0/build/three.module.js",
                "three/addons/": "https://unpkg.com/three@0.160.0/examples/jsm/",
                "fflate": "https://unpkg.com/fflate@0.7.4/esm/browser.js"
            }
        }
    </script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Tajawal:wght@400;500;700&display=swap');

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            -webkit-tap-highlight-color: transparent;
        }
        :root {
            --acc: #ff3366;
            --ok: #10b981;
            --warn: #f59e0b;
            --bg: #0b0b0e;
            --pan: rgba(14, 14, 18, 0.97);
            --card: rgba(255, 255, 255, 0.04);
            --bdr: rgba(255, 255, 255, 0.07);
            --txt: #e2e8f0;
            --dim: #475569;
            --mid: #94a3b8;
            --topH: 48px;
            --botH: 44px;
            --safe: env(safe-area-inset-bottom, 0px);
        }
        html,
        body {
            width: 100%;
            height: 100%;
            overflow: hidden;
            background: var(--bg);
            color: var(--txt);
            font-family: 'Tajawal', system-ui, sans-serif;
            touch-action: none;
            user-select: none;
            position: fixed;
            top: 0;
            left: 0;
        }

        /* ── TOP BAR (Landscape compact) ── */
        #top-bar {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            height: var(--topH);
            z-index: 300;
            background: var(--pan);
            border-bottom: 1px solid var(--bdr);
            display: flex;
            align-items: center;
            padding: 0 6px;
            gap: 4px;
            backdrop-filter: blur(14px);
            -webkit-backdrop-filter: blur(14px);
        }
        .logo {
            font-family: 'Space Mono', monospace;
            font-size: 12px;
            font-weight: 700;
            color: #fff;
            letter-spacing: 1px;
            white-space: nowrap;
            flex-shrink: 0;
            margin-left: 4px;
        }
        .logo b {
            color: var(--acc);
        }
        .mode-row {
            display: flex;
            gap: 2px;
            flex: 1;
            background: rgba(0, 0, 0, .4);
            border: 1px solid var(--bdr);
            border-radius: 8px;
            padding: 2px;
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
            scrollbar-width: none;
            min-width: 0;
        }
        .mode-row::-webkit-scrollbar {
            display: none;
        }
        .mbtn {
            flex-shrink: 0;
            background: none;
            border: none;
            color: var(--mid);
            font-size: 11px;
            font-weight: 700;
            padding: 4px 10px;
            cursor: pointer;
            border-radius: 6px;
            transition: all .2s;
            white-space: nowrap;
            font-family: 'Tajawal', sans-serif;
            min-height: 28px;
            min-width: 44px;
        }
        .mbtn.active {
            background: var(--acc);
            color: #fff;
        }
        .icon-btn {
            width: 32px;
            height: 32px;
            border-radius: 7px;
            border: 1px solid var(--bdr);
            background: var(--card);
            color: var(--mid);
            cursor: pointer;
            font-size: 15px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            transition: all .2s;
            background: rgba(255, 255, 255, .04);
        }
        .icon-btn:active {
            opacity: .6;
            transform: scale(.92);
        }
        .icon-btn.prim {
            background: rgba(255, 51, 102, .15);
            border-color: var(--acc);
            color: var(--acc);
        }

        /* ── BOTTOM BAR ── */
        #bot-bar {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            height: calc(var(--botH) + var(--safe));
            padding-bottom: var(--safe);
            z-index: 300;
            background: var(--pan);
            border-top: 1px solid var(--bdr);
            display: flex;
            align-items: stretch;
            padding: 0 2px;
        }
        .bitem {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 1px;
            font-size: 8px;
            color: var(--dim);
            flex: 1;
            cursor: pointer;
            padding: 2px 0;
            border: none;
            background: none;
            transition: all .15s;
            min-height: 36px;
        }
        .bitem .ico {
            font-size: 17px;
            line-height: 1;
        }
        .bitem.hi,
        .bitem.hi .ico {
            color: var(--acc);
        }
        .bitem:active {
            background: rgba(255, 255, 255, .05);
        }

        /* ── STATUS ── */
        #status-txt {
            position: fixed;
            bottom: calc(var(--botH) + 6px + var(--safe));
            left: 50%;
            transform: translateX(-50%);
            font-size: 9px;
            color: var(--mid);
            font-family: 'Space Mono', monospace;
            background: rgba(0, 0, 0, .7);
            padding: 2px 12px;
            border-radius: 4px;
            pointer-events: none;
            z-index: 280;
            white-space: nowrap;
            border: 1px solid var(--bdr);
            backdrop-filter: blur(6px);
        }

        /* ── SHEET OVERLAY ── */
        #sheet-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, .55);
            z-index: 380;
            display: none;
            opacity: 0;
            transition: opacity .25s;
        }
        #sheet-overlay.vis {
            display: block;
            opacity: 1;
        }

        /* ── BOTTOM SHEET ── */
        .bsheet {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            z-index: 400;
            background: rgba(15, 15, 20, 0.99);
            border-top: 1px solid var(--bdr);
            border-radius: 18px 18px 0 0;
            padding: 0 14px 20px;
            transform: translateY(100%);
            transition: transform .3s cubic-bezier(.4, 0, .2, 1);
            max-height: 70vh;
            overflow-y: auto;
            -webkit-overflow-scrolling: touch;
            padding-bottom: calc(20px + var(--safe));
        }
        .bsheet.open {
            transform: translateY(0);
        }
        .sh-handle {
            width: 36px;
            height: 4px;
            border-radius: 2px;
            background: #2a2a35;
            margin: 10px auto 12px;
            cursor: pointer;
        }
        .sh-title {
            font-size: 12px;
            font-weight: 700;
            color: var(--acc);
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 12px;
        }

        /* ── MODAL BRUSH ── */
        #modal-brush {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%) scale(0.92);
            width: 88%;
            max-width: 300px;
            background: rgba(15, 15, 20, 0.99);
            border: 1px solid var(--bdr);
            border-radius: 16px;
            padding: 18px;
            z-index: 400;
            opacity: 0;
            pointer-events: none;
            transition: all .25s cubic-bezier(.4, 0, .2, 1);
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.8);
            max-height: 80vh;
            overflow-y: auto;
        }
        #modal-brush.open {
            transform: translate(-50%, -50%) scale(1);
            opacity: 1;
            pointer-events: auto;
        }
        .modal-close {
            position: absolute;
            top: 12px;
            left: 14px;
            background: none;
            border: none;
            color: var(--dim);
            font-size: 15px;
            cursor: pointer;
            padding: 4px;
        }
        .modal-close:active {
            color: var(--acc);
        }

        /* ── FLOATING BTNS ── */
        .float-btn {
            position: fixed;
            right: 12px;
            width: 44px;
            height: 44px;
            border-radius: 50%;
            background: var(--pan);
            border: 2px solid var(--bdr);
            color: #fff;
            font-size: 18px;
            z-index: 350;
            display: none;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            box-shadow: 0 4px 14px rgba(0, 0, 0, 0.5);
            transition: all .2s;
            -webkit-touch-callout: none;
            backdrop-filter: blur(8px);
        }
        .float-btn:active {
            transform: scale(0.90);
        }
        .float-btn.active {
            background: var(--acc);
            border-color: var(--acc);
            box-shadow: 0 0 20px rgba(255, 51, 102, .4);
        }
        #floating-brush-btn {
            bottom: calc(var(--botH) + 16px + var(--safe));
        }
        #floating-fill-btn {
            bottom: calc(var(--botH) + 68px + var(--safe));
            font-size: 16px;
        }

        /* ── FILL CONFIRM ── */
        #fill-confirm-bar {
            position: fixed;
            top: calc(var(--topH) + 10px);
            left: 50%;
            transform: translateX(-50%);
            display: none;
            gap: 6px;
            z-index: 400;
            background: rgba(0, 0, 0, .88);
            padding: 10px 14px;
            border-radius: 12px;
            border: 1px solid var(--bdr);
            backdrop-filter: blur(10px);
            flex-direction: column;
            align-items: center;
            box-shadow: 0 6px 20px rgba(0, 0, 0, 0.6);
            width: 90%;
            max-width: 320px;
        }
        .fc-txt {
            font-size: 11px;
            color: #fff;
            margin-bottom: 4px;
            text-align: center;
        }
        .fc-row {
            display: flex;
            gap: 8px;
            width: 100%;
        }
        .fc-btn {
            flex: 1;
            padding: 7px 0;
            border: none;
            border-radius: 6px;
            font-weight: 700;
            cursor: pointer;
            font-family: 'Tajawal', sans-serif;
            font-size: 11px;
        }
        #btn-apply-fill {
            background: var(--ok);
            color: #fff;
        }
        #btn-cancel-fill {
            background: var(--dim);
            color: #fff;
        }

        /* ── SLIDERS ── */
        .sl-row {
            margin-bottom: 12px;
        }
        .sl-label {
            display: flex;
            justify-content: space-between;
            font-size: 12px;
            color: var(--mid);
            margin-bottom: 6px;
            align-items: center;
        }
        .sl-val {
            color: #fff;
            font-weight: 700;
            font-family: 'Space Mono', monospace;
            font-size: 12px;
        }
        input[type=range] {
            width: 100%;
            -webkit-appearance: none;
            height: 5px;
            border-radius: 3px;
            background: rgba(255, 255, 255, .1);
            outline: none;
            cursor: pointer;
        }
        input[type=range]::-webkit-slider-thumb {
            -webkit-appearance: none;
            width: 20px;
            height: 20px;
            border-radius: 50%;
            background: var(--acc);
            cursor: pointer;
            border: 2px solid rgba(255, 255, 255, .2);
        }
        input[type=range]::-moz-range-thumb {
            width: 20px;
            height: 20px;
            border-radius: 50%;
            background: var(--acc);
            cursor: pointer;
            border: 2px solid rgba(255, 255, 255, .2);
        }

        /* ── BONE LIST ── */
        #bone-list {
            display: flex;
            flex-direction: column;
            gap: 3px;
        }
        .bone-item {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 10px 12px;
            border-radius: 9px;
            cursor: pointer;
            font-size: 13px;
            border: 1px solid transparent;
            transition: all .15s;
            color: var(--mid);
        }
        .bone-item:active {
            opacity: .6;
        }
        .bone-item.sel {
            background: rgba(255, 51, 102, .12);
            border-color: rgba(255, 51, 102, .35);
            color: #fff;
        }
        .bdot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            flex-shrink: 0;
        }

        /* ── WEIGHT LEGEND ── */
        #wlegend {
            position: fixed;
            top: calc(var(--topH) + 8px);
            right: 10px;
            z-index: 250;
            background: var(--pan);
            border: 1px solid var(--bdr);
            border-radius: 8px;
            padding: 7px 10px;
            display: none;
            min-width: 90px;
            backdrop-filter: blur(8px);
        }
        .wl-bar {
            height: 7px;
            border-radius: 4px;
            background: linear-gradient(to right, #00f, #0ff, #0f0, #ff0, #f00);
            margin-bottom: 3px;
        }
        .wl-lbl {
            display: flex;
            justify-content: space-between;
            font-size: 8px;
            color: var(--dim);
            font-family: 'Space Mono', monospace;
        }

        /* ── PAINT HINT ── */
        #paint-hint {
            position: fixed;
            top: calc(var(--topH) + 8px);
            left: 50%;
            transform: translateX(-50%);
            background: rgba(0, 0, 0, .8);
            border: 1px solid var(--bdr);
            border-radius: 7px;
            padding: 5px 14px;
            font-size: 10px;
            color: var(--mid);
            z-index: 250;
            display: none;
            white-space: nowrap;
            backdrop-filter: blur(8px);
            text-align: center;
        }
        #paint-hint b {
            color: var(--acc);
        }

        /* ── BRUSH CURSOR ── */
        #brush-cursor {
            position: fixed;
            pointer-events: none;
            z-index: 240;
            display: none;
            border: 2px solid rgba(255, 51, 102, .8);
            border-radius: 50%;
            box-shadow: 0 0 14px rgba(255, 51, 102, .3);
            transform: translate(-50%, -50%);
            width: 30px;
            height: 30px;
        }

        /* ── TRANSFORM BAR (vertical for landscape) ── */
        #transform-bar {
            position: fixed;
            right: 8px;
            top: 50%;
            transform: translateY(-50%);
            z-index: 250;
            background: var(--pan);
            border: 1px solid var(--bdr);
            border-radius: 11px;
            padding: 5px;
            display: flex;
            flex-direction: column;
            gap: 4px;
            backdrop-filter: blur(12px);
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.4);
        }
        .tl-btn {
            width: 38px;
            height: 38px;
            border-radius: 7px;
            border: 1px solid var(--bdr);
            background: var(--card);
            color: var(--mid);
            cursor: pointer;
            font-size: 15px;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all .2s;
        }
        .tl-btn:active {
            transform: scale(.9);
        }
        .tl-btn.active {
            background: var(--acc);
            border-color: var(--acc);
            color: #fff;
        }
        .tl-sep {
            width: 100%;
            height: 1px;
            background: var(--bdr);
            margin: 2px 0;
        }

        /* ── RIGGING TOOLBAR (in top bar) ── */
        #rig-tools {
            display: none;
            gap: 3px;
            align-items: center;
            flex-shrink: 0;
        }
        #rig-tools.show {
            display: flex;
        }
        .rig-btn {
            padding: 4px 10px;
            border-radius: 6px;
            border: 1px solid var(--bdr);
            background: var(--card);
            color: var(--mid);
            font-size: 10px;
            font-weight: 700;
            cursor: pointer;
            font-family: 'Tajawal', sans-serif;
            transition: all .2s;
            min-height: 28px;
            white-space: nowrap;
        }
        .rig-btn:active {
            transform: scale(.92);
        }
        .rig-btn.active {
            background: var(--acc);
            border-color: var(--acc);
            color: #fff;
        }
        .rig-btn.danger {
            color: #ef4444;
            border-color: rgba(239, 68, 68, .3);
        }
        .rig-btn.danger:active {
            background: rgba(239, 68, 68, .2);
        }
        .rig-btn.ok {
            color: var(--ok);
            border-color: rgba(16, 185, 129, .3);
        }
        .rig-btn.ok:active {
            background: rgba(16, 185, 129, .15);
        }
        .rig-btn.warn {
            color: var(--warn);
            border-color: rgba(245, 158, 11, .3);
        }

        /* ── ACTION BTNS ── */
        .abt {
            width: 100%;
            padding: 11px;
            border-radius: 9px;
            border: 1px solid var(--bdr);
            background: var(--card);
            color: var(--mid);
            cursor: pointer;
            font-size: 12px;
            font-weight: 700;
            transition: all .2s;
            margin-bottom: 6px;
            font-family: 'Tajawal', sans-serif;
        }
        .abt:active {
            opacity: .6;
        }
        .abt.prim {
            background: rgba(255, 51, 102, .12);
            border-color: var(--acc);
            color: var(--acc);
        }
        .abt.ok {
            background: rgba(16, 185, 129, .12);
            border-color: var(--ok);
            color: var(--ok);
        }
        .abt.warn {
            background: rgba(245, 158, 11, .12);
            border-color: var(--warn);
            color: var(--warn);
        }
        .abt.danger {
            background: rgba(239, 68, 68, .1);
            border-color: rgba(239, 68, 68, .3);
            color: #ef4444;
        }
        hr.div {
            border: none;
            border-top: 1px solid var(--bdr);
            margin: 12px 0;
        }

        /* ── LOADING ── */
        #loading {
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, .92);
            display: none;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            z-index: 999;
            gap: 12px;
        }
        .spin {
            width: 32px;
            height: 32px;
            border: 2px solid rgba(255, 255, 255, .1);
            border-top-color: var(--acc);
            border-radius: 50%;
            animation: sp .7s linear infinite;
        }
        @keyframes sp {
            to {
                transform: rotate(360deg);
            }
        }
        #loading p {
            font-size: 12px;
            color: var(--mid);
            font-family: 'Space Mono', monospace;
        }

        /* ── RESPONSIVE TWEAKS ── */
        @media (max-width: 500px) {
            :root {
                --topH: 44px;
                --botH: 40px;
            }
            .logo {
                font-size: 10px;
            }
            .mbtn {
                font-size: 10px;
                padding: 3px 7px;
                min-height: 24px;
                min-width: 36px;
            }
            .icon-btn {
                width: 28px;
                height: 28px;
                font-size: 13px;
            }
            .tl-btn {
                width: 34px;
                height: 34px;
                font-size: 13px;
            }
            #transform-bar {
                right: 4px;
                padding: 4px;
                gap: 3px;
            }
            .float-btn {
                width: 38px;
                height: 38px;
                font-size: 16px;
                right: 8px;
            }
            #floating-brush-btn {
                bottom: calc(var(--botH) + 12px + var(--safe));
            }
            #floating-fill-btn {
                bottom: calc(var(--botH) + 56px + var(--safe));
            }
            .rig-btn {
                font-size: 9px;
                padding: 3px 7px;
                min-height: 24px;
            }
            #status-txt {
                font-size: 8px;
                padding: 1px 10px;
            }
            .bsheet {
                padding: 0 10px 16px;
                max-height: 60vh;
            }
            .bone-item {
                padding: 8px 10px;
                font-size: 12px;
            }
        }

        @media (orientation: landscape) and (max-height: 450px) {
            :root {
                --topH: 38px;
                --botH: 34px;
            }
            .logo {
                font-size: 9px;
            }
            .mbtn {
                font-size: 9px;
                padding: 2px 6px;
                min-height: 20px;
                min-width: 32px;
            }
            .icon-btn {
                width: 24px;
                height: 24px;
                font-size: 11px;
            }
            .tl-btn {
                width: 28px;
                height: 28px;
                font-size: 11px;
            }
            #transform-bar {
                right: 3px;
                padding: 3px;
                gap: 2px;
            }
            .float-btn {
                width: 32px;
                height: 32px;
                font-size: 14px;
                right: 6px;
            }
            #floating-brush-btn {
                bottom: calc(var(--botH) + 10px + var(--safe));
            }
            #floating-fill-btn {
                bottom: calc(var(--botH) + 48px + var(--safe));
            }
            .rig-btn {
                font-size: 8px;
                padding: 2px 6px;
                min-height: 20px;
            }
            #status-txt {
                font-size: 7px;
                padding: 1px 8px;
                bottom: calc(var(--botH) + 4px + var(--safe));
            }
            .bitem .ico {
                font-size: 14px;
            }
            .bitem {
                font-size: 7px;
                min-height: 28px;
            }
            #paint-hint {
                font-size: 8px;
                padding: 3px 10px;
                top: calc(var(--topH) + 4px);
            }
            #wlegend {
                padding: 4px 8px;
                min-width: 70px;
                top: calc(var(--topH) + 4px);
            }
            .wl-bar {
                height: 5px;
            }
            .bsheet {
                max-height: 50vh;
                padding: 0 8px 12px;
            }
            .sh-title {
                font-size: 10px;
                margin-bottom: 8px;
            }
            .bone-item {
                padding: 6px 8px;
                font-size: 11px;
            }
            .abt {
                padding: 7px;
                font-size: 10px;
            }
            #modal-brush {
                max-width: 260px;
                padding: 14px;
            }
        }
    </style>
</head>
<body>

    <div id="loading"><div class="spin"></div><p id="load-txt">جاري التحميل...</p></div>

    <!-- TOP BAR -->
    <div id="top-bar">
        <div class="logo">3D<b>.</b>RIG</div>
        <div class="mode-row">
            <button class="mbtn active" onclick="setMode('OBJECT',this)">Object</button>
            <button class="mbtn" onclick="setMode('RIGGING',this)">Rigging</button>
            <button class="mbtn" onclick="setMode('PAINT',this)">Paint</button>
        </div>

        <!-- Rigging tools -->
        <div id="rig-tools">
            <button class="rig-btn" id="btn-add-bone" onclick="toggleAddBone()">✚ عظمة</button>
