    <script type="module">
        import * as THREE from 'three';
        import { OrbitControls } from 'three/addons/controls/OrbitControls.js';
        import { TransformControls } from 'three/addons/controls/TransformControls.js';
        import { GLTFLoader } from 'three/addons/loaders/GLTFLoader.js';
        import { FBXLoader } from 'three/addons/loaders/FBXLoader.js';
        import { OBJLoader } from 'three/addons/loaders/OBJLoader.js';
        import { GLTFExporter } from 'three/addons/exporters/GLTFExporter.js';

        /* ─── STATE ────────────────────────────────────────────── */
        let scene, camera, renderer, orbit, txCtrl, raycaster;
        const modelGroup = new THREE.Group();
        let skinnedMeshes = [];
        let boneMarkers = [];
        let boneLines = [];
        const origMats = new Map();
        let currentMode = 'OBJECT';
        let selBone = null;
        let selBoneIdx = -1;
        let brushOn = false;
        let fillModeOn = false;
        let isPainting = false;
        let wireframe = false;
        let fillSelection = null;
        let addBoneMode = false;
        let boneContainer = new THREE.Group();
        let userBones = [];
        let isRigApplied = false;
        let tempMeshForRig = null; // mesh being rigged

        const mouse = new THREE.Vector2();
        const BONE_COLS = [0xffd700, 0xff6b35, 0x4ecdc4, 0xa8dadc, 0xe9c46a, 0xe76f51, 0x2ec4b6, 0xff9f1c, 0x845ec2, 0xff9671];

        /* ─── INIT ─────────────────────────────────────────────── */
        init();

        function init() {
            scene = new THREE.Scene();
            scene.background = new THREE.Color(0x0b0b0e);
            scene.fog = new THREE.Fog(0x0b0b0e, 40, 80);
            scene.add(modelGroup);

            camera = new THREE.PerspectiveCamera(45, innerWidth / innerHeight, 0.01, 500);
            camera.position.set(0, 4, 10);

            renderer = new THREE.WebGLRenderer({ antialias: true, powerPreference: "default" });
            renderer.setSize(innerWidth, innerHeight);
            renderer.setPixelRatio(Math.min(devicePixelRatio, 1.5));
            renderer.shadowMap.enabled = true;
            renderer.shadowMap.type = THREE.PCFSoftShadowMap;
            document.body.appendChild(renderer.domElement);

            // Lights
            const amb = new THREE.AmbientLight(0xffffff, 0.5);
            scene.add(amb);
            const sun = new THREE.DirectionalLight(0xffffff, 1.2);
            sun.position.set(6, 12, 6);
            sun.castShadow = true;
            sun.shadow.mapSize.set(512, 512);
            scene.add(sun);
            const fill = new THREE.DirectionalLight(0x6688ff, 0.25);
            fill.position.set(-5, 2, -5);
            scene.add(fill);
            const grid = new THREE.GridHelper(30, 30, 0x1f1f2a, 0x151519);
            scene.add(grid);

            orbit = new OrbitControls(camera, renderer.domElement);
            orbit.enableDamping = true;
            orbit.dampingFactor = 0.08;
            orbit.target.set(0, 2.5, 0);

            txCtrl = new TransformControls(camera, renderer.domElement);
            txCtrl.addEventListener('dragging-changed', e => orbit.enabled = !e.value);
            scene.add(txCtrl);

            raycaster = new THREE.Raycaster();
            raycaster.params.Mesh.threshold = 0.35;

            const cv = renderer.domElement;
            cv.addEventListener('pointerdown', onPtrDown);
            cv.addEventListener('pointermove', onPtrMove);
            cv.addEventListener('pointerup', onPtrUp);
            cv.addEventListener('pointercancel', onPtrUp);
            window.addEventListener('resize', onResize);
            window.addEventListener('keydown', onKeyDown);
            document.getElementById('file-input').addEventListener('change', handleFile);

            setupFloatingButtons();
            buildDefault();
            animate();
        }

        function setupFloatingButtons() {
            const fBtn = document.getElementById('floating-brush-btn');
            const fillBtn = document.getElementById('floating-fill-btn');
            let pressTimer, isLongPress = false;

            const startPress = (e) => {
                if (e.type === 'touchstart') e.preventDefault();
                isLongPress = false;
                pressTimer = setTimeout(() => { isLongPress = true;
                    openBrushModal(); }, 400);
            };
            const endPress = (e) => {
                if (e.type === 'touchend') e.preventDefault();
                clearTimeout(pressTimer);
                if (!isLongPress) toggleBrush();
            };
            fBtn.addEventListener('touchstart', startPress, { passive: false });
            fBtn.addEventListener('touchend', endPress, { passive: false });
            fBtn.addEventListener('mousedown', startPress);
            fBtn.addEventListener('mouseup', endPress);
            fBtn.addEventListener('mouseleave', () => clearTimeout(pressTimer));
            fBtn.oncontextmenu = e => e.preventDefault();

            fillBtn.addEventListener('click', () => toggleFillMode());
        }

        /* ─── DEFAULT MODEL ────────────────────────────────────── */
        function buildDefault() {
            const geo = new THREE.CylinderGeometry(0.45, 0.38, 6, 10, 24);
            geo.translate(0, 3, 0);
            const bRoot = mkBone('Root', 0, 0, 0),
                bHip = mkBone('Hip', 0, 1.8, 0),
                bChest = mkBone('Chest', 0, 1.8, 0),
                bHead = mkBone('Head', 0, 1.8, 0);
            bRoot.add(bHip);
            bHip.add(bChest);
            bChest.add(bHead);
            const skel = new THREE.Skeleton([bRoot, bHip, bChest, bHead]);
            const pos = geo.attributes.position,
                N = pos.count;
            const si = new Uint16Array(N * 4),
                sw = new Float32Array(N * 4);
            for (let i = 0; i < N; i++) {
                const t = THREE.MathUtils.clamp(pos.getY(i) / 6, 0, 1);
                const seg = Math.min(Math.floor(t * 3), 2);
                const frac = smoothstep((t * 3) - seg);
                const b = i * 4;
                si[b] = seg;
                sw[b] = 1 - frac;
                si[b + 1] = seg + 1;
                sw[b + 1] = frac;
            }
            geo.setAttribute('skinIndex', new THREE.Uint16BufferAttribute(si, 4));
            geo.setAttribute('skinWeight', new THREE.Float32BufferAttribute(sw, 4));
            const mat = new THREE.MeshStandardMaterial({ color: 0x4488ff, roughness: 0.55, metalness: 0.1 });
            const mesh = new THREE.SkinnedMesh(geo, mat);
            mesh.name = 'DefaultBody';
            mesh.castShadow = mesh.receiveShadow = true;
            mesh.add(bRoot);
            mesh.bind(skel);
            mesh.normalizeSkinWeights();
            modelGroup.add(mesh);
            skinnedMeshes = [mesh];
            isRigApplied = true;
            rebuildBoneViz(skel);
            refreshBoneList();
            txCtrl.attach(modelGroup);
            updStatus();
        }

        function mkBone(n, x, y, z) {
            const b = new THREE.Bone();
            b.name = n;
            b.position.set(x, y, z);
            return b;
        }

        function smoothstep(t) { return t * t * (3 - 2 * t); }

        /* ─── BONE MARKERS ─────────────────────────────────────── */
        function rebuildBoneViz(skel) {
            clearBoneViz();
            if (!skel) return;
            skel.bones.forEach((b, idx) => {
                const col = BONE_COLS[idx % BONE_COLS.length];
                const m = new THREE.Mesh(
                    new THREE.SphereGeometry(0.6, 6, 4),
                    new THREE.MeshBasicMaterial({ color: col, depthTest: false, transparent: true, opacity: .9 })
                );
                m.renderOrder = 999;
                m.userData = { bone: b, boneIndex: idx, baseColor: col };
                b.userData.marker = m;
                scene.add(m);
                boneMarkers.push(m);
                if (b.parent && b.parent.isBone) {
                    const pts = new Float32Array(6);
                    const lg = new THREE.BufferGeometry();
                    lg.setAttribute('position', new THREE.BufferAttribute(pts, 3));
                    const ln = new THREE.Line(lg, new THREE.LineBasicMaterial({ color: col, depthTest: false,
                        transparent: true, opacity: .35 }));
                    ln.renderOrder = 998;
                    ln.userData = { p: b.parent, c: b };
                    scene.add(ln);
                    boneLines.push(ln);
                }
            });
            updateBoneMarkers();
        }

        function clearBoneViz() {
            boneMarkers.forEach(m => scene.remove(m));
            boneLines.forEach(l => scene.remove(l));
            boneMarkers = [];
            boneLines = [];
        }

        function updateBoneMarkers() {
            boneMarkers.forEach(m => {
                if (m.userData.bone) {
                    m.position.setFromMatrixPosition(m.userData.bone.matrixWorld);
                    const dist = camera.position.distanceTo(m.position);
                    const sc = Math.max(0.008, dist * 0.005);
                    m.scale.setScalar(sc);
                }
            });
            boneLines.forEach(ln => {
                const pa = ln.geometry.attributes.position;
                if (ln.userData.p && ln.userData.c) {
                    const p = new THREE.Vector3().setFromMatrixPosition(ln.userData.p.matrixWorld);
                    const c = new THREE.Vector3().setFromMatrixPosition(ln.userData.c.matrixWorld);
                    pa.setXYZ(0, p.x, p.y, p.z);
                    pa.setXYZ(1, c.x, c.y, c.z);
                    pa.needsUpdate = true;
                }
            });
        }

        function setBoneViz(v) {
            boneMarkers.forEach(m => m.visible = v);
            boneLines.forEach(l => l.visible = v);
        }

        /* ─── SELECT BONE (improved hit) ────────────────────── */
        function selectBoneAtPointer(clientX, clientY) {
            setMouseXY(clientX, clientY);
            raycaster.setFromCamera(mouse, camera);

            // First check bone markers with expanded threshold
            const hits = raycaster.intersectObjects(boneMarkers);
            if (hits.length) {
                selectMarker(hits[0].object);
                return true;
            }

            // Fallback: check distance from ray to bone positions
            const ray = raycaster.ray;
            let best = null,
                bestDist = Infinity;
            for (const m of boneMarkers) {
                const pos = m.position.clone();
                const dist = ray.distanceToPoint(pos);
                // Use a threshold based on camera distance
                const camDist = camera.position.distanceTo(pos);
                const threshold = Math.max(0.08, camDist * 0.015);
                if (dist < threshold && dist < bestDist) {
                    bestDist = dist;
                    best = m;
                }
            }
            if (best) {
                selectMarker(best);
                return true;
            }
            return false;
        }

        function selectMarker(marker) {
            if (selBone?.userData?.marker) {
                const prev = selBone.userData.marker;
                prev.material.color.setHex(prev.userData.baseColor);
            }
            selBone = marker.userData.bone;
            selBoneIdx = marker.userData.boneIndex;
            marker.material.color.setHex(0xff3366);
            document.getElementById('sel-bone-name').textContent = selBone.name || ('Bone ' + selBoneIdx);

            document.querySelectorAll('.bone-item').forEach(el =>
                el.classList.toggle('sel', parseInt(el.dataset.idx) === selBoneIdx)
            );

            if (currentMode === 'RIGGING' && !addBoneMode) {
                txCtrl.attach(selBone);
            }
            if (currentMode === 'PAINT') applyWeightViz();
            updStatus();
        }

        window.selectFromList = (idx) => {
            const m = boneMarkers.find(b => b.userData.boneIndex === idx);
            if (m) selectMarker(m);
            closeSheet();
        };

        /* ─── MODE ─────────────────────────────────────────────── */
        window.setMode = (mode, btn) => {
            if (brushOn) toggleBrush();
            if (fillModeOn) toggleFillMode();
            if (addBoneMode) toggleAddBone();

            currentMode = mode;
            document.querySelectorAll('.mbtn').forEach(b => b.classList.remove('active'));
            if (btn) btn.classList.add('active');

            txCtrl.detach();
            const tbr = document.getElementById('transform-bar');
            const hint = document.getElementById('paint-hint');
            const wleg = document.getElementById('wlegend');
            const fBtn = document.getElementById('floating-brush-btn');
            const fFillBtn = document.getElementById('floating-fill-btn');
            const rigTools = document.getElementById('rig-tools');

            tbr.style.display = (mode === 'PAINT') ? 'none' : 'flex';
            hint.style.display = (mode === 'PAINT') ? 'block' : 'none';
            wleg.style.display = (mode === 'PAINT') ? 'block' : 'none';
            fBtn.style.display = (mode === 'PAINT') ? 'flex' : 'none';
            fFillBtn.style.display = (mode === 'PAINT') ? 'flex' : 'none';
            rigTools.classList.toggle('show', mode === 'RIGGING');

            if (mode === 'OBJECT') {
                restoreMats();
                setBoneViz(false);
                if (modelGroup.children.length) txCtrl.attach(modelGroup);
            } else if (mode === 'RIGGING') {
                restoreMats();
                setBoneViz(true);
                if (selBone && !addBoneMode) txCtrl.attach(selBone);
                else if (!addBoneMode) txCtrl.detach();
            } else if (mode === 'PAINT') {
                setBoneViz(true);
                if (selBone) applyWeightViz();
            }
            updStatus();
        };

        /* ─── ADD BONE MODE ───────────────────────────────────── */
        window.toggleAddBone = () => {
            if (currentMode !== 'RIGGING') {
                setMode('RIGGING', document.querySelectorAll('.mbtn')[1]);
            }
            addBoneMode = !addBoneMode;
            const btn = document.getElementById('btn-add-bone');
            btn.classList.toggle('active', addBoneMode);
            if (addBoneMode) {
                txCtrl.detach();
                document.getElementById('paint-hint').innerHTML = '✚ انقر على <b>المجسم</b> لإضافة عظمة';
                document.getElementById('paint-hint').style.display = 'block';
                document.getElementById('paint-hint').style.top = 'calc(var(--topH) + 44px)';
            } else {
                document.getElementById('paint-hint').style.display = 'none';
                if (selBone) txCtrl.attach(selBone);
            }
            updStatus();
        };

        function createBoneAtPoint(point, mesh) {
            if (!mesh) return;

            // Find nearest existing bone for parenting
            let parentBone = null;
            let minDist = Infinity;
            const pos = point.clone();

            // Get all bones from the mesh's skeleton or from boneMarkers
            const allBones = boneMarkers.map(m => m.userData.bone).filter(b => b);
            for (const b of allBones) {
                const bp = new THREE.Vector3().setFromMatrixPosition(b.matrixWorld);
                const d = pos.distanceTo(bp);
                if (d < minDist) { minDist = d;
                    parentBone = b; }
            }

            // If no bones, create root at point
            if (!parentBone) {
                const root = mkBone('Root_' + (userBones.length + 1), pos.x, pos.y, pos.z);
                // Add to mesh
                if (mesh.isSkinnedMesh) {
                    mesh.add(root);
                } else {
                    // Fallback: add to modelGroup
                    modelGroup.add(root);
                }
                userBones.push(root);
                // Rebuild skeleton
                rebuildSkeletonFromBones(mesh);
                return;
            }

            // Create new bone at point, parent to nearest
            const newBone = mkBone('Bone_' + (userBones.length + 1), pos.x - parentBone.position.x, pos.y - parentBone
                .position.y, pos.z - parentBone.position.z);
            // Actually, we need to set position in world space, then parent
            // But THREE.Bone position is relative to parent
            // So we need to convert world pos to local pos relative to parent
            const parentWorldPos = new THREE.Vector3().setFromMatrixPosition(parentBone.matrixWorld);
            const localPos = pos.clone().sub(parentWorldPos);
            newBone.position.copy(localPos);

            // Find the mesh to add the bone to
            let targetMesh = mesh;
            if (!targetMesh.isSkinnedMesh) {
                // Find the skinned mesh that contains the parent bone
                for (const sm of skinnedMeshes) {
                    if (sm.skeleton && sm.skeleton.bones.includes(parentBone)) {
                        targetMesh = sm;
                        break;
                    }
                }
            }

            if (targetMesh && targetMesh.isSkinnedMesh) {
                parentBone.add(newBone);
                userBones.push(newBone);
                rebuildSkeletonFromBones(targetMesh);
            } else {
                // Fallback: add to modelGroup
                parentBone.add(newBone);
                userBones.push(newBone);
                // Try to find a mesh to rebuild
                if (skinnedMeshes.length) {
                    rebuildSkeletonFromBones(skinnedMeshes[0]);
                }
            }
        }

        function rebuildSkeletonFromBones(mesh) {
            if (!mesh || !mesh.isSkinnedMesh) return;
            // Collect all bones in hierarchy
            const allBones = [];
            const rootBones = [];
            const children = mesh.children;
            for (const c of children) {
                if (c.isBone) {
                    rootBones.push(c);
                    collectBones(c, allBones);
                }
            }

            if (!allBones.length) return;

            // Build new skeleton
            const skel = new THREE.Skeleton(allBones);
            // Keep the same geometry, re-bind
            const geo = mesh.geometry.clone();
            const mat = mesh.material.clone();

            // Remove old mesh
            const oldName = mesh.name;
            const oldPos = mesh.position.clone();
            const oldRot = mesh.quaternion.clone();
            const oldScale = mesh.scale.clone();
            const oldParent = mesh.parent;

            mesh.parent.remove(mesh);

            // Create new mesh
            const newMesh = new THREE.SkinnedMesh(geo, mat);
            newMesh.name = oldName;
            newMesh.position.copy(oldPos);
            newMesh.quaternion.copy(oldRot);
            newMesh.scale.copy(oldScale);
            newMesh.castShadow = newMesh.receiveShadow = true;

            // Add bones to new mesh
            for (const b of rootBones) {
                newMesh.add(b);
            }

            // Bind
            newMesh.bind(skel);
            newMesh.normalizeSkinWeights();

            // Replace in modelGroup
            if (oldParent) {
                oldParent.add(newMesh);
            } else {
                modelGroup.add(newMesh);
            }

            // Update references
            const idx = skinnedMeshes.indexOf(mesh);
            if (idx !== -1) skinnedMeshes[idx] = newMesh;
            else skinnedMeshes.push(newMesh);

            // Update bone markers
            clearBoneViz();
            rebuildBoneViz(skel);

            // Re-select bone if it exists
            if (selBone) {
                const newMarker = boneMarkers.find(m => m.userData.bone === selBone);
                if (newMarker) selectMarker(newMarker);
            }

            refreshBoneList();
            isRigApplied = true;
            updStatus();
        }

        function collectBones(bone, arr) {
            arr.push(bone);
            for (const c of bone.children) {
                if (c.isBone) collectBones(c, arr);
            }
        }

        /* ─── DELETE BONE ─────────────────────────────────────── */
        window.deleteSelectedBone = () => {
            if (!selBone) { alert('اختر عظمة أولاً'); return; }
            if (!confirm('حذف العظمة "' + (selBone.name || '') + '"؟')) return;

            const parent = selBone.parent;
            const children = [...selBone.children];

            // Reparent children to parent
            for (const c of children) {
                if (c.isBone) {
                    if (parent && parent.isBone) {
                        parent.add(c);
                    } else {
                        // Find the mesh root
                        const mesh = skinnedMeshes.find(m => m.skeleton && m.skeleton.bones.includes(selBone));
                        if (mesh) mesh.add(c);
                    }
                }
            }

            // Remove bone
            const mesh = skinnedMeshes.find(m => m.skeleton && m.skeleton.bones.includes(selBone));
            if (selBone.parent) {
                selBone.parent.remove(selBone);
            } else if (mesh) {
                mesh.remove(selBone);
            }

            const idx = userBones.indexOf(selBone);
            if (idx !== -1) userBones.splice(idx, 1);

            selBone = null;
            selBoneIdx = -1;

            if (mesh) {
                rebuildSkeletonFromBones(mesh);
            } else {
                // Just refresh viz
                clearBoneViz();
                if (skinnedMeshes.length && skinnedMeshes[0].skeleton) {
                    rebuildBoneViz(skinnedMeshes[0].skeleton);
                }
                refreshBoneList();
            }

            document.getElementById('sel-bone-name').textContent = '—';
            txCtrl.detach();
            updStatus();
        };

        /* ─── APPLY RIG ───────────────────────────────────────── */
        window.applyRig = () => {
            if (!skinnedMeshes.length) { alert('لا يوجد نموذج لتطبيق العظام عليه'); return; }
            const mesh = skinnedMeshes[0];
            if (!mesh.isSkinnedMesh) { alert('النموذج ليس SkinnedMesh'); return; }

            // Check if we have bones
            const rootBones = [];
            for (const c of mesh.children) {
                if (c.isBone) rootBones.push(c);
            }
            if (!rootBones.length) {
                // Try to get bones from userBones
                if (userBones.length) {
                    for (const b of userBones) {
                        if (b.parent === mesh || b.parent === modelGroup) {
                            rootBones.push(b);
                        }
                    }
                }
            }

            if (!rootBones.length) { alert('لا توجد عظام لتطبيقها. أضف عظاماً أولاً.'); return; }

            // Collect all bones
            const allBones = [];
            for (const b of rootBones) collectBones(b, allBones);
            if (!allBones.length) { alert('لا توجد عظام'); return; }

            // Build skeleton
            const skel = new THREE.Skeleton(allBones);

            // Compute default weights (distance-based)
            const geo = mesh.geometry;
            const pos = geo.attributes.position;
            const N = pos.count;
            const si = new Uint16Array(N * 4);
            const sw = new Float32Array(N * 4);

            // For each vertex, find the closest bone
            const bonePositions = allBones.map(b => {
                const p = new THREE.Vector3().setFromMatrixPosition(b.matrixWorld);
                return { bone: b, pos: p };
            });

            for (let i = 0; i < N; i++) {
                const v = new THREE.Vector3(pos.getX(i), pos.getY(i), pos.getZ(i));
                // Transform vertex to world space
                v.applyMatrix4(mesh.matrixWorld);

                // Find closest bones
                const dists = bonePositions.map((bp, idx) => {
                    const d = v.distanceTo(bp.pos);
                    return { idx, d };
                });
                dists.sort((a, b) => a.d - b.d);

                // Assign weights to top 4 bones
                const total = dists.slice(0, 4).reduce((sum, d) => sum + (d.d < 0.001 ? 1 : 1 / (d.d + 0.001)), 0);
                const base = i * 4;
                for (let j = 0; j < 4; j++) {
                    if (j < dists.length) {
                        const d = dists[j];
                        const w = d.d < 0.001 ? 1 : (1 / (d.d + 0.001)) / total;
                        si[base + j] = d.idx;
                        sw[base + j] = w;
                    } else {
                        si[base + j] = 0;
                        sw[base + j] = 0;
                    }
                }
            }

            geo.setAttribute('skinIndex', new THREE.Uint16BufferAttribute(si, 4));
            geo.setAttribute('skinWeight', new THREE.Float32BufferAttribute(sw, 4));

            // Re-bind mesh
            const oldName = mesh.name;
            const oldMat = mesh.material.clone();
            const newMesh = new THREE.SkinnedMesh(geo, oldMat);
            newMesh.name = oldName;
            newMesh.position.copy(mesh.position);
            newMesh.quaternion.copy(mesh.quaternion);
            newMesh.scale.copy(mesh.scale);
            newMesh.castShadow = newMesh.receiveShadow = true;

            // Transfer bones
            for (const b of rootBones) {
                newMesh.add(b);
            }

            mesh.parent.remove(mesh);
            modelGroup.add(newMesh);

            const idx = skinnedMeshes.indexOf(mesh);
            if (idx !== -1) skinnedMeshes[idx] = newMesh;
            else skinnedMeshes.push(newMesh);

            newMesh.bind(skel);
            newMesh.normalizeSkinWeights();

            clearBoneViz();
            rebuildBoneViz(skel);
            refreshBoneList();
            isRigApplied = true;

            // Select first bone
            if (boneMarkers.length) {
                selectMarker(boneMarkers[0]);
            }

            alert('✓ تم تطبيق العظام والأوزان الافتراضية بنجاح!');
            updStatus();
        };

        /* ─── FILL MODE ────────────────────────────────────────── */
        window.toggleFillMode = () => {
            if (!selBone) { alert('اختر عظمة أولاً'); return; }
            if (brushOn) toggleBrush();
            fillModeOn = !fillModeOn;
            const btn = document.getElementById('floating-fill-btn');
            btn.classList.toggle('active', fillModeOn);
            if (fillModeOn) {
                orbit.enabled = false;
                document.getElementById('paint-hint').innerHTML = '<b>🪣 طلاء كلي</b> — انقر على جزء منفصل';
            } else {
                cancelFill();
                orbit.enabled = true;
                document.getElementById('paint-hint').innerHTML = 'وضع التلوين — اختر <b>عظمة</b> ثم فعّل الفرشاة';
            }
            updStatus();
        };

        function getConnectedVertices(mesh, startIdx) {
            if (!mesh.userData.adj) {
                const posArr = mesh.geometry.attributes.position.array;
                const N = mesh.geometry.attributes.position.count;
                const idxA = mesh.geometry.index;
                const indices = idxA ? idxA.array : null;
                const facesCount = indices ? indices.length / 3 : N / 3;
                const adj = new Map();
                const addE = (u, v) => {
                    if (!adj.has(u)) adj.set(u, []);
                    if (!adj.has(v)) adj.set(v, []);
                    adj.get(u).push(v);
                    adj.get(v).push(u);
                };
                for (let i = 0; i < facesCount; i++) {
                    const v1 = indices ? indices[i * 3] : i * 3;
                    const v2 = indices ? indices[i * 3 + 1] : i * 3 + 1;
                    const v3 = indices ? indices[i * 3 + 2] : i * 3 + 2;
                    addE(v1, v2);
                    addE(v2, v3);
                    addE(v3, v1);
                }
                const posMap = new Map();
                const getH = (x, y, z) => `${x.toFixed(3)}_${y.toFixed(3)}_${z.toFixed(3)}`;
                for (let i = 0; i < N; i++) {
                    const h = getH(posArr[i * 3], posArr[i * 3 + 1], posArr[i * 3 + 2]);
                    if (!posMap.has(h)) posMap.set(h, []);
                    posMap.get(h).push(i);
                }
                for (const verts of posMap.values()) {
                    for (let i = 1; i < verts.length; i++) addE(verts[0], verts[i]);
                }
                mesh.userData.adj = adj;
            }
            const adj = mesh.userData.adj;
            const visited = new Set();
            const q = [startIdx];
            visited.add(startIdx);
            let head = 0;
            while (head < q.length) {
                const curr = q[head++];
                const neighbors = adj.get(curr);
                if (neighbors) {
                    for (const nxt of neighbors) {
                        if (!visited.has(nxt)) { visited.add(nxt);
                            q.push(nxt); }
                    }
                }
            }
            return Array.from(visited);
        }

        function highlightSelection(mesh, indices) {
            const ca = mesh.geometry.attributes.color.array;
            for (const i of indices) {
                ca[i * 3] = 1;
                ca[i * 3 + 1] = 1;
                ca[i * 3 + 2] = 1;
            }
            mesh.geometry.attributes.color.needsUpdate = true;
        }

        window.cancelFill = () => {
            if (fillSelection) {
                refreshVC(fillSelection.mesh, selBoneIdx);
                fillSelection = null;
            }
            document.getElementById('fill-confirm-bar').style.display = 'none';
        };

        window.applyFillWeight = () => {
            if (!fillSelection) return;
            const target = parseFloat(document.getElementById('brush-weight').value);
            const { mesh, indices } = fillSelection;
            const si = mesh.geometry.attributes.skinIndex;
            const sw = mesh.geometry.attributes.skinWeight;
            for (const i of indices) {
                blendW(i, si, sw, target, 1.0);
            }
            sw.needsUpdate = true;
            si.needsUpdate = true;
            refreshVC(mesh, selBoneIdx);
            cancelFill();
            toggleFillMode();
        };

        /* ─── BRUSH TOGGLE ─────────────────────────────────────── */
        window.toggleBrush = () => {
            if (fillModeOn) toggleFillMode();
            if (!brushOn && currentMode !== 'PAINT') {
                const btn = document.querySelectorAll('.mbtn')[2];
                setMode('PAINT', btn);
            }
            if (!brushOn && !selBone) {
                alert('اختر عظمة أولاً من قائمة 🦴');
                return;
            }
            brushOn = !brushOn;
            const btn = document.getElementById('floating-brush-btn');
            if (brushOn) {
                btn.classList.add('active');
                orbit.enabled = false;
                document.getElementById('brush-cursor').style.display = 'block';
                updateCursorSize();
                document.getElementById('paint-hint').innerHTML = '<b>🖌️ الفرشاة تعمل</b> — ارسم على النموذج';
            } else {
                btn.classList.remove('active');
                orbit.enabled = true;
                document.getElementById('brush-cursor').style.display = 'none';
                document.getElementById('paint-hint').innerHTML = 'وضع التلوين — اختر <b>عظمة</b> ثم فعّل الفرشاة';
            }
            updStatus();
        };

        /* ─── WEIGHT VIZ ───────────────────────────────────────── */
        function applyWeightViz() {
            if (selBoneIdx === -1) return;
            for (const mesh of skinnedMeshes) {
                if (!origMats.has(mesh)) origMats.set(mesh, mesh.material);
                refreshVC(mesh, selBoneIdx);
                mesh.material = new THREE.MeshBasicMaterial({ vertexColors: true });
                if (!mesh.userData.wireOverlay) {
                    const wireMat = new THREE.MeshBasicMaterial({ color: 0x000000, wireframe: true, transparent: true,
                        opacity: 0.3, depthWrite: false });
                    const wireMesh = new THREE.SkinnedMesh(mesh.geometry, wireMat);
                    wireMesh.bind(mesh.skeleton, mesh.bindMatrix);
                    mesh.add(wireMesh);
                    mesh.userData.wireOverlay = wireMesh;
                }
                mesh.userData.wireOverlay.visible = true;
            }
        }

        function refreshVC(mesh, bIdx) {
            const geo = mesh.geometry;
            const si = geo.attributes.skinIndex,
                sw = geo.attributes.skinWeight;
            if (!si || !sw) return;
            const N = si.count;
            if (!geo.attributes.color || geo.attributes.color.count !== N)
                geo.setAttribute('color', new THREE.BufferAttribute(new Float32Array(N * 3), 3));
            const ca = geo.attributes.color;
            const siArr = si.array,
                swArr = sw.array,
                caArr = ca.array;
            for (let i = 0; i < N; i++) {
                let w = 0;
                const idx = i * 4;
                if (Math.round(siArr[idx]) === bIdx) w += swArr[idx];
                if (Math.round(siArr[idx + 1]) === bIdx) w += swArr[idx + 1];
                if (Math.round(siArr[idx + 2]) === bIdx) w += swArr[idx + 2];
                if (Math.round(siArr[idx + 3]) === bIdx) w += swArr[idx + 3];
                const { r, g, b } = heatmap(THREE.MathUtils.clamp(w, 0, 1));
                const cIdx = i * 3;
                caArr[cIdx] = r;
                caArr[cIdx + 1] = g;
                caArr[cIdx + 2] = b;
            }
            ca.needsUpdate = true;
        }

        function heatmap(t) {
            let r, g, b;
            if (t < .25) { r = 0;
                g = t * 4;
                b = 1; } else if (t < .5) { r = 0;
                g = 1;
                b = 1 - (t - .25) * 4; } else if (t < .75) { r = (t - .5) * 4;
                g = 1;
                b = 0; } else { r = 1;
                g = 1 - (t - .75) * 4;
                b = 0; }
            return { r, g, b };
        }

        function restoreMats() {
            for (const m of skinnedMeshes) {
                if (origMats.has(m)) m.material = origMats.get(m);
                if (m.userData.wireOverlay) m.userData.wireOverlay.visible = false;
            }
        }

        /* ─── PAINT ENGINE ─────────────────────────────────────── */
        function doPaint(cx, cy) {
            if (!brushOn || currentMode !== 'PAINT' || selBoneIdx === -1) return;
            setMouseXY(cx, cy);
            raycaster.setFromCamera(mouse, camera);
            const hits = raycaster.intersectObjects(skinnedMeshes);
            if (!hits.length) return;
            const { object: mesh, point } = hits[0];

            const radiusVal = parseFloat(document.getElementById('brush-radius').value);
            const wTarget = parseFloat(document.getElementById('brush-weight').value);
            const strength = parseFloat(document.getElementById('brush-strength').value);

            const cursorRadiusPx = (radiusVal * 60) / 2;
            const hitDist = camera.position.distanceTo(point);
            const fovRad = THREE.MathUtils.degToRad(camera.fov);
            const worldHeight = 2 * hitDist * Math.tan(fovRad / 2);
            const worldUnitsPerPx = worldHeight / innerHeight;
            const worldRadius = cursorRadiusPx * worldUnitsPerPx;

            const posA = mesh.geometry.attributes.position;
            const si = mesh.geometry.attributes.skinIndex;
            const sw = mesh.geometry.attributes.skinWeight;
            if (!posA || !si || !sw) return;

            const meshScale = new THREE.Vector3().setFromMatrixScale(mesh.matrixWorld);
            const maxScale = Math.max(meshScale.x, meshScale.y, meshScale.z);
            const localRadius = worldRadius / maxScale;
            const localRadiusSq = localRadius * localRadius;

            const localPoint = mesh.worldToLocal(point.clone());
            const px = localPoint.x,
                py = localPoint.y,
                pz = localPoint.z;
            const posArr = posA.array;

            let dirty = false;
            for (let i = 0; i < posA.count; i++) {
                const idx = i * 3;
                const dx = posArr[idx] - px,
                    dy = posArr[idx + 1] - py,
                    dz = posArr[idx + 2] - pz;
                const distSq = dx * dx + dy * dy + dz * dz;
                if (distSq >= localRadiusSq) continue;
                const d = Math.sqrt(distSq) * maxScale;
                const falloff = (1 - (d / worldRadius));
                const finalStrength = THREE.MathUtils.clamp(falloff * strength, 0, 1);
                blendW(i, si, sw, wTarget, finalStrength);
                dirty = true;
            }
            if (dirty) { sw.needsUpdate = true;
                si.needsUpdate = true;
                refreshVC(mesh, selBoneIdx); }
        }

        function blendW(vi, si, sw, target, strength) {
            let slot = -1,
                minW = Infinity,
                minSlot = 0;
            for (let j = 0; j < 4; j++) {
                if (Math.round(si.getComponent(vi, j)) === selBoneIdx) { slot = j; break; }
                const w = sw.getComponent(vi, j);
                if (w < minW) { minW = w;
                    minSlot = j; }
            }
            if (slot === -1) { slot = minSlot;
                si.setComponent(vi, slot, selBoneIdx); }
            const cur = sw.getComponent(vi, slot);
            sw.setComponent(vi, slot, THREE.MathUtils.lerp(cur, target, strength));
            let sum = 0;
            for (let j = 0; j < 4; j++) sum += sw.getComponent(vi, j);
            if (sum > 1e-4)
                for (let j = 0; j < 4; j++) sw.setComponent(vi, j, sw.getComponent(vi, j) / sum);
            else sw.setComponent(vi, slot, 1.0);
        }

        /* ─── POINTER EVENTS ───────────────────────────────────── */
        function onPtrDown(e) {
            if (txCtrl.dragging || txCtrl.axis !== null) return;

            // In rigging mode with add bone active
            if (currentMode === 'RIGGING' && addBoneMode) {
                setMouseXY(e.clientX, e.clientY);
                raycaster.setFromCamera(mouse, camera);
                const hits = raycaster.intersectObjects(skinnedMeshes);
                if (hits.length) {
                    const pt = hits[0].point;
                    const mesh = hits[0].object;
                    createBoneAtPoint(pt, mesh);
                    // Select the newly created bone (last one)
                    if (boneMarkers.length) {
                        selectMarker(boneMarkers[boneMarkers.length - 1]);
                    }
                    // Keep add bone mode active
                    return;
                }
                return;
            }

            // Try to select a bone first (in rigging or paint mode)
            if (currentMode === 'RIGGING' || currentMode === 'PAINT') {
                if (selectBoneAtPointer(e.clientX, e.clientY)) {
                    if (currentMode === 'RIGGING' && !addBoneMode) {
                        txCtrl.attach(selBone);
                    }
                    return;
                }
            }

            // Transform controls
            if (currentMode === 'RIGGING' && !addBoneMode && selBone) {
                // Bone already selected, let transform controls handle it
                return;
            }

            // Fill mode
            if (currentMode === 'PAINT' && fillModeOn) {
                if (fillSelection) return;
                setMouseXY(e.clientX, e.clientY);
                raycaster.setFromCamera(mouse, camera);
                const hits = raycaster.intersectObjects(skinnedMeshes);
                if (hits.length) {
                    const hit = hits[0];
                    const startIdx = hit.face ? hit.face.a : null;
                    if (startIdx !== null) {
                        const mesh = hit.object;
                        const connected = getConnectedVertices(mesh, startIdx);
                        fillSelection = { mesh, indices: connected };
                        highlightSelection(mesh, connected);
                        document.getElementById('fill-confirm-bar').style.display = 'flex';
                    }
                }
                return;
            }

            // Paint mode with brush
            if (currentMode === 'PAINT' && brushOn) {
                isPainting = true;
                doPaint(e.clientX, e.clientY);
                return;
            }

            // Object mode: select objects?
            if (currentMode === 'OBJECT') {
                // Just let orbit controls handle it
            }
        }

        function onPtrMove(e) {
            if (brushOn && currentMode === 'PAINT') {
                const cur = document.getElementById('brush-cursor');
                cur.style.left = e.clientX + 'px';
                cur.style.top = e.clientY + 'px';
            }
            if (!isPainting) return;
            doPaint(e.clientX, e.clientY);
        }

        function onPtrUp() { isPainting = false; }

        function setMouseXY(cx, cy) {
            const r = renderer.domElement.getBoundingClientRect();
            mouse.x = ((cx - r.left) / r.width) * 2 - 1;
            mouse.y = -((cy - r.top) / r.height) * 2 + 1;
        }

        /* ─── CURSOR SIZE ──────────────────────────────────────── */
        window.updateCursorSize = () => {
            const radiusVal = parseFloat(document.getElementById('brush-radius').value);
            const px = radiusVal * 60;
            const cur = document.getElementById('brush-cursor');
            cur.style.width = px + 'px';
            cur.style.height = px + 'px';
        };

        /* ─── KEYBOARD ─────────────────────────────────────────── */
        function onKeyDown(e) {
            if (['INPUT', 'TEXTAREA'].includes(document.activeElement.tagName)) return;
            switch (e.key.toLowerCase()) {
                case 'g':
                    setTransform('translate');
                    break;
                case 'r':
                    setTransform('rotate');
                    break;
                case 's':
                    setTransform('scale');
                    break;
                case 'w':
                    toggleWireframe();
                    break;
                case 'tab':
                    e.preventDefault();
                    const ms = ['OBJECT', 'RIGGING', 'PAINT'];
                    const ni = (ms.indexOf(currentMode) + 1) % 3;
                    setMode(ms[ni], document.querySelectorAll('.mbtn')[ni]);
                    break;
                case 'delete':
                case 'backspace':
                    if (currentMode === 'RIGGING' && selBone) deleteSelectedBone();
                    break;
            }
        }

        /* ─── UI ───────────────────────────────────────────────── */
        window.setTransform = (mode) => {
            if (currentMode === 'PAINT') return;
            txCtrl.setMode(mode);
            document.querySelectorAll('.tl-btn[id^="t-"]').forEach(b => b.classList.remove('active'));
            const el = document.getElementById('t-' + mode);
            if (el) el.classList.add('active');
        };

        window.resetCamera = () => {
            camera.position.set(0, 4, 10);
            orbit.target.set(0, 2.5, 0);
            orbit.update();
        };

        window.toggleWireframe = () => {
            wireframe = !wireframe;
            document.getElementById('t-wire').classList.toggle('active', wireframe);
            for (const m of skinnedMeshes) {
                const mat = origMats.has(m) ? origMats.get(m) : m.material;
                if (mat && 'wireframe' in mat) mat.wireframe = wireframe;
            }
        };

        window.resetBoneWeights = () => {
            if (!selBone) { alert('اختر عظمة أولاً'); return; }
            if (!confirm('إعادة ضبط أوزان "' + (selBone.name || '') + '"؟')) return;
            for (const mesh of skinnedMeshes) {
                const si = mesh.geometry.attributes.skinIndex;
                const sw = mesh.geometry.attributes.skinWeight;
                if (!si || !sw) continue;
                for (let i = 0; i < sw.count; i++)
                    for (let j = 0; j < 4; j++)
                        if (Math.round(si.getComponent(i, j)) === selBoneIdx) sw.setComponent(i, j, 0);
                sw.needsUpdate = true;
                refreshVC(mesh, selBoneIdx);
            }
        };

        window.applyPaint = () => {
            if (brushOn) toggleBrush();
            if (fillModeOn) toggleFillMode();
            restoreMats();
            setMode('OBJECT', document.querySelectorAll('.mbtn')[0]);
            closeSheet();
        };

        /* ─── SHEETS ───────────────────────────────────────────── */
        window.openSheet = (id) => {
