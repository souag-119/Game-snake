            ov.classList.remove('vis');
            setTimeout(() => ov.style.display = 'none', 260);
        };

        /* ─── STATUS & BONE LIST ───────────────────────────────── */
        function updStatus() {
            const bTxt = selBone ? selBone.name : 'لا توجد عظمة';
            let extra = '';
            if (brushOn) extra = ' · 🖌️';
            if (fillModeOn) extra = ' · 🪣';
            if (addBoneMode) extra = ' · ✚';
            document.getElementById('status-txt').textContent = currentMode + ' · ' + bTxt + extra;
        }

        function refreshBoneList() {
            const el = document.getElementById('bone-list');
            if (!boneMarkers.length) {
                el.innerHTML = '<div style="font-size:12px;color:var(--dim)">لا توجد عظام</div>';
                return;
            }
            el.innerHTML = boneMarkers.map(m =>
                `<div class="bone-item" data-idx="${m.userData.boneIndex}"
                     onclick="selectFromList(${m.userData.boneIndex})">
                    <div class="bdot" style="background:#${m.userData.baseColor.toString(16).padStart(6,'0')}"></div>
                    <span>${m.userData.bone.name || 'Bone ' + m.userData.boneIndex}</span>
                </div>`
            ).join('');
        }

        /* ─── FILE IMPORT ──────────────────────────────────────── */
        function handleFile(e) {
            const file = e.target.files[0];
            if (!file) return;
            const url = URL.createObjectURL(file);
            const ext = file.name.split('.').pop().toLowerCase();

            if (!['obj', 'fbx', 'gltf', 'glb'].includes(ext)) {
                alert('صيغة غير مدعومة: .' + ext + '\nالصيغ المدعومة: OBJ · FBX · GLTF · GLB');
                e.target.value = '';
                return;
            }

            showLoad('جاري تحميل ' + file.name);
            modelGroup.clear();
            skinnedMeshes = [];
            origMats.clear();
            clearBoneViz();
            txCtrl.detach();
            selBone = null;
            selBoneIdx = -1;
            brushOn = false;
            fillModeOn = false;
            addBoneMode = false;
            cancelFill();
            userBones = [];
            isRigApplied = false;
            document.getElementById('btn-add-bone').classList.remove('active');
            document.getElementById('rig-tools').classList.remove('show');

            const finish = (obj) => {
                try {
                    const box = new THREE.Box3().setFromObject(obj);
                    const size = box.getSize(new THREE.Vector3());
                    const ctr = box.getCenter(new THREE.Vector3());
                    const sc = 5 / Math.max(size.x, size.y, size.z, 0.01);
                    obj.scale.setScalar(sc);
                    obj.position.sub(ctr.multiplyScalar(sc));

                    const basicMat = new THREE.MeshStandardMaterial({ color: 0x94a3b8, roughness: 0.6, metalness: 0.1 });
                    obj.traverse(c => {
                        if (c.isMesh) {
                            c.material = basicMat;
                            if (c.isSkinnedMesh) skinnedMeshes.push(c);
                        }
                    });

                    modelGroup.add(obj);

                    // Auto-rig if no skinned mesh
                    if (!skinnedMeshes.length) {
                        const plain = [];
                        obj.traverse(c => { if (c.isMesh) plain.push(c); });
                        for (const p of plain) autoRig(p);
                    }

                    const seen = new Set();
                    for (const m of skinnedMeshes) {
                        if (m.skeleton && !seen.has(m.skeleton)) {
                            seen.add(m.skeleton);
                            rebuildBoneViz(m.skeleton);
                            isRigApplied = true;
                        }
                    }

                    // If we have bones, mark as rig applied
                    if (boneMarkers.length) isRigApplied = true;

                    refreshBoneList();
                    setMode('OBJECT', document.querySelectorAll('.mbtn')[0]);
                    txCtrl.attach(modelGroup);
                } catch (err) {
                    console.error(err);
                    alert('خطأ في معالجة النموذج: ' + (err.message || err));
                } finally {
                    hideLoad();
                    e.target.value = '';
                    URL.revokeObjectURL(url);
                }
            };

            const fail = (err) => {
                hideLoad();
                e.target.value = '';
                URL.revokeObjectURL(url);
                alert('فشل تحميل الملف.\n' + (err.message || err));
            };

            if (ext === 'gltf' || ext === 'glb') {
                new GLTFLoader().load(url, r => finish(r.scene), undefined, fail);
            } else if (ext === 'fbx') {
                new FBXLoader().load(url, r => finish(r), undefined, fail);
            } else if (ext === 'obj') {
                new OBJLoader().load(url, r => finish(r), undefined, fail);
            }
        }

        function autoRig(mesh) {
            const geo = mesh.geometry;
            if (!geo?.attributes?.position) return;
            const pos = geo.attributes.position,
                N = pos.count;
            let minY = Infinity,
                maxY = -Infinity;
            for (let i = 0; i < N; i++) { const y = pos.getY(i);
                minY = Math.min(minY, y);
                maxY = Math.max(maxY, y); }
            const h = maxY - minY || 1;
            const bA = mkBone('Root', 0, minY, 0),
                bB = mkBone('Mid', 0, h * .5, 0),
                bC = mkBone('Top', 0, h * .5, 0);
            bA.add(bB);
            bB.add(bC);
            const skel = new THREE.Skeleton([bA, bB, bC]);
            const si = new Uint16Array(N * 4),
                sw = new Float32Array(N * 4);
            for (let i = 0; i < N; i++) {
                const t = THREE.MathUtils.clamp((pos.getY(i) - minY) / h, 0, 1);
                const b = i * 4;
                let b0, b1, frac;
                if (t < .5) { b0 = 0;
                    b1 = 1;
                    frac = smoothstep(t * 2); } else { b0 = 1;
                    b1 = 2;
                    frac = smoothstep((t - .5) * 2); }
                si[b] = b0;
                sw[b] = 1 - frac;
                si[b + 1] = b1;
                sw[b + 1] = frac;
            }
            geo.setAttribute('skinIndex', new THREE.Uint16BufferAttribute(si, 4));
            geo.setAttribute('skinWeight', new THREE.Float32BufferAttribute(sw, 4));
            const sm = new THREE.SkinnedMesh(geo, mesh.material);
            sm.name = (mesh.name || 'Mesh') + '_Rig';
            sm.add(bA);
            sm.bind(skel);
            sm.normalizeSkinWeights();
            modelGroup.add(sm);
            skinnedMeshes.push(sm);
            isRigApplied = true;
        }

        /* ─── EXPORT ───────────────────────────────────────────── */
        window.exportModel = () => {
            if (!modelGroup.children.length) { alert('لا يوجد نموذج!'); return; }
            restoreMats();
            modelGroup.traverse(node => { if (node.isSkinnedMesh) node.skeleton.update(); });

            const exporter = new GLTFExporter();
            exporter.parse(modelGroup, gltf => {
                const output = JSON.stringify(gltf, null, 2);
                const blob = new Blob([output], { type: 'application/json' });
                const url = URL.createObjectURL(blob);
                const a = document.createElement('a');
                a.href = url;
                a.download = 'rigged_model.gltf';
                a.click();
                setTimeout(() => URL.revokeObjectURL(url), 1000);
            }, err => { alert('خطأ في التصدير: ' + err.message); }, { trs: true, onlyVisible: false, binary: false });
        };

        /* ─── LOOP ─────────────────────────────────────────────── */
        function animate() {
            requestAnimationFrame(animate);
            if (currentMode !== 'OBJECT') {
                updateBoneMarkers();
            }
            orbit.update();
            renderer.render(scene, camera);
        }

        function onResize() {
            camera.aspect = innerWidth / innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(innerWidth, innerHeight);
        }

        function showLoad(t) {
            document.getElementById('load-txt').textContent = t;
            document.getElementById('loading').style.display = 'flex';
        }

        function hideLoad() {
            document.getElementById('loading').style.display = 'none';
        }

        /* ─── EXPOSE GLOBALS ───────────────────────────────────── */
        window.THREE = THREE;
        window.scene = scene;
        window.camera = camera;
        window.modelGroup = modelGroup;
        window.skinnedMeshes = skinnedMeshes;
        window.boneMarkers = boneMarkers;
        window.selBone = selBone;
        window.selBoneIdx = selBoneIdx;
        window.currentMode = currentMode;
        window.selectBoneAtPointer = selectBoneAtPointer;
        window.createBoneAtPoint = createBoneAtPoint;
        window.rebuildSkeletonFromBones = rebuildSkeletonFromBones;
        window.collectBones = collectBones;
        window.userBones = userBones;
        window.isRigApplied = isRigApplied;

        console.log('🎯 3D Rig & Paint Studio loaded.');
        console.log('📐 Landscape optimized · Bone creation · Enhanced selection');
    </script>
</body>
</html>
